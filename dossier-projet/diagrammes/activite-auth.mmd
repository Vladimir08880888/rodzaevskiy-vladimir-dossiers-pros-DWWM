%% Diagramme d'Activité — Authentification (Mission 1)
%% Reminder Famille
%%
%% Couvre register + login + accès route protégée.

flowchart TD
    START([Visiteur ouvre l'app]) --> CHOICE{Compte existant ?}

    CHOICE -- Non --> REG[Remplit formulaire<br/>register : email, mdp, nom, prénom]
    REG --> V1{Validation front<br/>email + mdp >= 8}
    V1 -- KO --> REG
    V1 -- OK --> POST_REG[POST /api/auth/register]
    POST_REG --> V2{Validation back<br/>validators/auth}
    V2 -- KO 400 --> REG
    V2 -- OK --> CHECK_EMAIL{Email déjà<br/>en base ?}
    CHECK_EMAIL -- Oui 409 --> REG
    CHECK_EMAIL -- Non --> HASH[bcrypt cost 10<br/>password → password_hash]
    HASH --> GEN_TOK[randomHex 24<br/>→ calendar_token]
    GEN_TOK --> INSERT[INSERT INTO users]
    INSERT --> JWT_SIGN[signToken : HS256, 7j]
    JWT_SIGN --> RESPONSE_REG[201 Created<br/>{token, user}]

    CHOICE -- Oui --> LOG[Remplit formulaire login<br/>email + mdp]
    LOG --> POST_LOG[POST /api/auth/login]
    POST_LOG --> FIND_USER{Utilisateur<br/>trouvé ?}
    FIND_USER -- Non 401 --> LOG
    FIND_USER -- Oui --> COMPARE{bcrypt.compare<br/>OK ?}
    COMPARE -- Non 401 --> LOG
    COMPARE -- Oui --> JWT_SIGN2[signToken]
    JWT_SIGN2 --> RESPONSE_LOG[200 OK<br/>{token, user}]

    RESPONSE_REG --> STORE[localStorage.setItem<br/>token JWT]
    RESPONSE_LOG --> STORE
    STORE --> NAV[Navigate to /dashboard]

    NAV --> PROTECTED[GET /api/auth/me<br/>Authorization: Bearer ...]
    PROTECTED --> MW{authRequired middleware<br/>jwt.verify}
    MW -- token invalide --> EXPIRED[401 → logout<br/>+ redirect /login]
    MW -- token OK --> CTRL[authController.me]
    CTRL --> FETCH[SELECT * FROM users WHERE id=?]
    FETCH --> RES_ME[200 {user data}]
    RES_ME --> DASHBOARD([Dashboard affiché])

    classDef start fill:#10b981,color:#fff
    classDef decision fill:#f59e0b,color:#000
    classDef error fill:#ef4444,color:#fff
    classDef ok fill:#6366f1,color:#fff
    class START,DASHBOARD start
    class CHOICE,V1,V2,CHECK_EMAIL,FIND_USER,COMPARE,MW decision
    class EXPIRED error
    class HASH,GEN_TOK,JWT_SIGN,JWT_SIGN2,STORE,INSERT ok
