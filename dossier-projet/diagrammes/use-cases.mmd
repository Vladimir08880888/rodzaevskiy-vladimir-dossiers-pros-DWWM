%% Diagramme de Cas d'Utilisation — UML
%% Reminder Famille
%%
%% Acteurs :
%%   - Visiteur     : utilisateur non authentifié
%%   - Membre       : utilisateur authentifié (parent ou enfant)
%%   - Parent       : membre avec role=parent dans une famille
%%   - Enfant       : membre avec role=child dans une famille
%%   - Admin famille : parent + is_admin=true (peut approuver, régénérer code…)
%%   - Calendrier   : système externe (iPhone Cal / Google Cal) consommateur d'iCal
%%
%% Mermaid ne supporte pas la notation officielle UML use-case (ellipses) ;
%% on utilise un flowchart pour rester compatible GitHub.

flowchart LR
    V((👤 Visiteur))
    M((👤 Membre))
    P((👨 Parent))
    E((👧 Enfant))
    A((⭐ Admin))
    C((📱 Calendrier<br/>externe))

    %% Cas d'utilisation Visiteur
    V --> UC1["S'inscrire"]
    V --> UC2["Se connecter"]

    %% Cas Membre (commun)
    M --> UC3["Voir son dashboard"]
    M --> UC4["Modifier son profil"]
    M --> UC5["Changer mot de passe"]
    M --> UC6["Quitter une famille"]
    M --> UC7["Créer une tâche personnelle"]
    M --> UC8["Compléter sa tâche personnelle"]
    M --> UC9["Obtenir son URL iCal"]
    M --> UC10["Créer une famille (devient admin)"]
    M --> UC11["Rejoindre une famille via code"]

    %% Cas Parent
    P --> UC12["Créer une tâche familiale"]
    P --> UC13["Modifier une tâche familiale"]
    P --> UC14["Supprimer une tâche familiale"]
    P --> UC15["Assigner tâche à un enfant"]
    P --> UC16["Valider tâche terminée par enfant"]
    P --> UC17["Rejeter tâche terminée par enfant"]

    %% Cas Enfant
    E --> UC18["Voir ses tâches assignées"]
    E --> UC19["Marquer tâche assignée comme faite<br/>(→ en attente de validation)"]
    E --> UC20["Commenter une tâche"]

    %% Cas Admin
    A --> UC21["Approuver demande d'adhésion"]
    A --> UC22["Régénérer code d'invitation"]
    A --> UC23["Réinitialiser MDP d'un membre"]
    A --> UC24["Modifier rôle d'un membre"]
    A --> UC25["Renommer / supprimer la famille"]

    %% Cas Calendrier externe
    C --> UC26["S'abonner au flux .ics<br/>(URL avec token)"]
    C --> UC27["Polling périodique du flux"]
    C --> UC28["Afficher VALARM<br/>(notification système 1j avant)"]

    %% Héritage acteurs (notation flèche en pointillés)
    M -.->|spécialise| P
    M -.->|spécialise| E
    P -.->|spécialise| A

    classDef actor fill:#fce7f3,stroke:#ec4899,color:#1e1b3a,font-weight:bold
    classDef uc    fill:#e0e7ff,stroke:#6366f1,color:#1e1b3a
    class V,M,P,E,A,C actor
    class UC1,UC2,UC3,UC4,UC5,UC6,UC7,UC8,UC9,UC10,UC11,UC12,UC13,UC14,UC15,UC16,UC17,UC18,UC19,UC20,UC21,UC22,UC23,UC24,UC25,UC26,UC27,UC28 uc
